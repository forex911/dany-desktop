{
  "name": "dany-downloader",
  "version": "1.0.0",
  "description": "Dany Downloader — Premium desktop media downloader",
  "main": "electron/main.js",
  "author": "FOREX911",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.dany.downloader",
    "productName": "Dany Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "backend/**/*",
      "!backend/bin/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}